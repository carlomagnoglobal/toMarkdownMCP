{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "toMarkdown Viewer",
  "version": "0.1.0",
  "identifier": "com.carlomagnoglobal.tomarkdown",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "toMarkdown Viewer",
        "width": 1240,
        "height": 840,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
